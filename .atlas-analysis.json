  "keyFeatures": [
    "Moderation commands (ban, kick, purge)",
    "Social roleplay interactions (hug, kiss, pat)",
    "Anime & manga lookups via AniList and Jikan",
    "Game server status queries (Minecraft, CS:GO)",
    "Slash command support via gcommands",
    "MongoDB persistence for guild config",
    "Canvas-based welcome cards and graphics",
    "Activity status rotation"
  ],
  "publicApiSurface": [
    "/ban - Ban a user from the server",
    "/kick - Kick a user from the server",
    "/purge - Bulk delete messages",
    "/hug - Hug another user",
    "/kiss - Kiss another user",
    "/pat - Pat another user",
    "/bite - Bite another user",
    "/slap - Slap another user",
    "/anime - Search for anime on AniList",
    "/manga - Search for manga on AniList",
    "/mal - MyAnimeList anime search",
    "/al - AniList profile lookup",
    "/minecraft - Check Minecraft server status",
    "/css - Check Counter-Strike server status",
    "/ping - Check bot latency",
    "/uptime - Display bot uptime",
    "/help - List all commands",
    "/botinfo - Display bot information",
    "/serverinfo - Display server information",
    "/userinfo - Display user information",
    "/avatar - Get user avatar",
    "/say - Make the bot say something",
    "/meme - Get random meme",
    "/animeme - Get random anime meme",
    "/activities - Start Discord activities",
    "/djs - Search Discord.js documentation"
  ]
}
