{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Yato Discord Bot",
  "theme": "almond",
  "colors": {
    "primary": "#7289DA",
    "light": "#99AAF5",
    "dark": "#5B6EAE"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/qonTesq/yato"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/qonTesq/yato"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "installation"]
          },
          {
            "group": "Configuration",
            "pages": ["configuration/environment", "configuration/mongodb", "configuration/discord-setup"]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/moderation",
              "features/social-roleplay",
              "features/anime-manga",
              "features/game-servers",
              "features/utilities"
            ]
          },
          {
            "group": "Deployment",
            "pages": ["deployment/hosting", "deployment/heroku", "deployment/docker"]
          }
        ]
      },
      {
        "tab": "Commands",
        "groups": [
          {
            "group": "Command Reference",
            "pages": [
              "commands/overview",
              "commands/moderation",
              "commands/social",
              "commands/anime",
              "commands/games",
              "commands/utilities",
              "commands/misc"
            ]
          }
        ]
      },
      {
        "tab": "Development",
        "groups": [
          {
            "group": "Extending Yato",
            "pages": [
              "development/architecture",
              "development/adding-commands",
              "development/custom-events",
              "development/database-models"
            ]
          },
          {
            "group": "Migration",
            "pages": [
              "development/upgrading-discordjs",
              "development/modernization"
            ]
          }
        ]
      }
    ]
  }
}
